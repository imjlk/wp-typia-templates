import apiFetch from "@wordpress/api-fetch";
import { parse, serialize } from "@wordpress/blocks";

import { validators } from "../validators";
import migrationConfig from "./config";
import { deprecated } from "./generated/deprecated";
import migrationRegistry from "./generated/registry";
import {
	type ManifestDocument,
	manifestMatchesDocument,
	summarizeVersionDelta,
} from "./helpers";

export interface MigrationAnalysis {
	needsMigration: boolean;
	currentVersion: string;
	targetVersion: string;
	confidence: number;
	reasons: string[];
	warnings: string[];
	affectedFields: {
		added: string[];
		changed: string[];
		removed: string[];
	};
}

export interface BlockScanResult {
	analysis: MigrationAnalysis;
	attributes: Record<string, unknown>;
	blockName: string;
	blockPath: number[];
	postId: number;
	postTitle: string;
	postType: string;
	rawContent: string;
	restBase: string;
}

export interface BatchMigrationResult {
	errors: Array<{ postId: number; reason: string }>;
	failed: number;
	successful: number;
	total: number;
}

export function detectBlockMigration(attributes: Record<string, unknown>): MigrationAnalysis {
	const currentValidation = validators.validate(attributes as any);
	if (currentValidation.success) {
		return {
			needsMigration: false,
			currentVersion: migrationRegistry.currentVersion,
			targetVersion: migrationRegistry.currentVersion,
			confidence: 1,
			reasons: ["Current Typia validator accepted the attributes."],
			warnings: [],
			affectedFields: {
				added: [],
				changed: [],
				removed: [],
			},
		};
	}

	for (const entry of migrationRegistry.entries) {
		if (manifestMatchesDocument(entry.manifest as ManifestDocument, attributes)) {
			const delta = summarizeVersionDelta(
				entry.manifest as ManifestDocument,
				migrationRegistry.currentManifest as ManifestDocument,
			);

			return {
				needsMigration: true,
				currentVersion: entry.fromVersion,
				targetVersion: migrationRegistry.currentVersion,
				confidence: 0.95,
				reasons: [
					`Snapshot ${entry.fromVersion} matched this block.`,
					...(entry.rule.unresolved.length > 0
						? [`Migration rule still has unresolved items: ${entry.rule.unresolved.join(", ")}`]
						: []),
				],
				warnings: entry.rule.unresolved.length > 0 ? [...entry.rule.unresolved] : [],
				affectedFields: delta,
			};
		}
	}

	return {
		needsMigration: true,
		currentVersion: "unknown",
		targetVersion: migrationRegistry.currentVersion,
		confidence: 0.2,
		reasons: ["No legacy snapshot matched and current Typia validator rejected the attributes."],
		warnings: ["Manual migration review is required because the block does not match any supported snapshot."],
		affectedFields: {
			added: [],
			changed: [],
			removed: [],
		},
	};
}

export function autoMigrate(attributes: Record<string, unknown>) {
	const currentValidation = validators.validate(attributes as any);
	if (currentValidation.success) {
		return attributes;
	}

	for (const entry of migrationRegistry.entries) {
		if (manifestMatchesDocument(entry.manifest as ManifestDocument, attributes)) {
			const migrated = entry.rule.migrate(attributes);
			const postValidation = validators.validate(migrated as any);
			if (!postValidation.success) {
				throw new Error(
					`Migration ${entry.fromVersion} -> ${migrationRegistry.currentVersion} failed current validation: ${JSON.stringify(postValidation.errors)}`,
				);
			}
			return migrated;
		}
	}

	throw new Error("Unable to migrate block attributes because no supported snapshot matched.");
}

export async function scanSiteForMigrations(
	blockName: string = migrationConfig.blockName,
): Promise<BlockScanResult[]> {
	const postTypes = await fetchEditablePostTypes();
	const results: BlockScanResult[] = [];

	for (const postType of postTypes) {
		const posts = await fetchAllPosts(postType.rest_base);
		for (const post of posts) {
			const content = post?.content?.raw;
			if (typeof content !== "string" || content.length === 0) {
				continue;
			}

			const blocks = parse(content);
			walkBlocks(blocks, [], (block, blockPath) => {
				if (block.name !== blockName) {
					return;
				}

				const analysis = detectBlockMigration((block.attributes ?? {}) as Record<string, unknown>);
				if (analysis.needsMigration || analysis.warnings.length > 0) {
					results.push({
						analysis,
						attributes: (block.attributes ?? {}) as Record<string, unknown>,
						blockName,
						blockPath,
						postId: post.id,
						postTitle: post?.title?.rendered ?? `Post ${post.id}`,
						postType: postType.slug,
						rawContent: content,
						restBase: postType.rest_base,
					});
				}
			});
		}
	}

	return results;
}

export async function batchMigrateScanResults(
	results: BlockScanResult[],
	{ dryRun = false }: { dryRun?: boolean } = {},
): Promise<BatchMigrationResult> {
	const grouped = groupResultsByPost(results);
	const summary: BatchMigrationResult = {
		errors: [],
		failed: 0,
		successful: 0,
		total: Object.keys(grouped).length,
	};

	for (const group of Object.values(grouped)) {
		try {
			const migratedContent = migratePostContent(group.results, group.rawContent);
			if (!dryRun) {
				await apiFetch({
					body: {
						content: migratedContent,
					},
					method: "POST",
					path: `/wp/v2/${group.restBase}/${group.postId}`,
				});
			}
			summary.successful += 1;
		} catch (error) {
			summary.failed += 1;
			summary.errors.push({
				postId: group.postId,
				reason: error instanceof Error ? error.message : String(error),
			});
		}
	}

	return summary;
}

export function generateMigrationReport(scanResults: BlockScanResult[]): string {
	const needsMigration = scanResults.filter((result) => result.analysis.needsMigration);
	const byVersion = needsMigration.reduce<Record<string, BlockScanResult[]>>((accumulator, result) => {
		const key = result.analysis.currentVersion;
		if (!accumulator[key]) {
			accumulator[key] = [];
		}
		accumulator[key].push(result);
		return accumulator;
	}, {});

	let report = `# ${migrationConfig.blockName} Migration Report\n\n`;
	report += `- Current version: ${migrationRegistry.currentVersion}\n`;
	report += `- Supported deprecated entries: ${deprecated.length}\n`;
	report += `- Scan results needing attention: ${scanResults.length}\n\n`;

	for (const [version, entries] of Object.entries(byVersion)) {
		report += `## ${version}\n`;
		for (const entry of entries) {
			report += `- ${entry.postTitle} (#${entry.postId})`;
			if (entry.analysis.warnings.length > 0) {
				report += ` — warnings: ${entry.analysis.warnings.join(", ")}`;
			}
			report += "\n";
		}
		report += "\n";
	}

	return report;
}

export const migrationUtils = {
	getStats() {
		return {
			blockName: migrationConfig.blockName,
			currentVersion: migrationRegistry.currentVersion,
			deprecatedEntries: deprecated.length,
			supportedVersions: migrationRegistry.entries.map((entry) => entry.fromVersion),
		};
	},
	testMigration(attributes: Record<string, unknown>) {
		return autoMigrate(attributes);
	},
};

async function fetchEditablePostTypes(): Promise<Array<{ rest_base: string; slug: string }>> {
	const response = (await apiFetch({
		parse: false,
		path: "/wp/v2/types?context=edit",
	})) as Response;
	const payload = (await response.json()) as Record<string, any>;

	return Object.values(payload)
		.filter((postType) => postType?.viewable && postType?.rest_base)
		.map((postType) => ({
			rest_base: postType.rest_base,
			slug: postType.slug,
		}));
}

async function fetchAllPosts(restBase: string): Promise<any[]> {
	let page = 1;
	let totalPages = 1;
	const entries: any[] = [];

	do {
		const response = (await apiFetch({
			parse: false,
			path: `/wp/v2/${restBase}?context=edit&per_page=100&page=${page}`,
		})) as Response;
		totalPages = Number.parseInt(response.headers.get("X-WP-TotalPages") ?? "1", 10);
		entries.push(...((await response.json()) as any[]));
		page += 1;
	} while (page <= totalPages);

	return entries;
}

function walkBlocks(
	blocks: any[],
	pathPrefix: number[],
	visitor: (block: any, path: number[]) => void,
) {
	blocks.forEach((block, index) => {
		const blockPath = [...pathPrefix, index];
		visitor(block, blockPath);
		if (Array.isArray(block.innerBlocks) && block.innerBlocks.length > 0) {
			walkBlocks(block.innerBlocks, blockPath, visitor);
		}
	});
}

function groupResultsByPost(results: BlockScanResult[]) {
	return results.reduce<Record<string, { postId: number; rawContent: string; restBase: string; results: BlockScanResult[] }>>(
		(accumulator, result) => {
			const key = `${result.restBase}:${result.postId}`;
			if (!accumulator[key]) {
				accumulator[key] = {
					postId: result.postId,
					rawContent: result.rawContent,
					restBase: result.restBase,
					results: [],
				};
			}
			accumulator[key].results.push(result);
			return accumulator;
		},
		{},
	);
}

function migratePostContent(results: BlockScanResult[], rawContent: string): string {
	const replacements = new Map(
		results.map((result) => [result.blockPath.join("."), autoMigrate(result.attributes)]),
	);
	const blocks = parse(rawContent);
	const nextBlocks = replaceBlocks(blocks, [], replacements);
	return serialize(nextBlocks);
}

function replaceBlocks(blocks: any[], pathPrefix: number[], replacements: Map<string, Record<string, unknown>>) {
	return blocks.map((block, index) => {
		const blockPath = [...pathPrefix, index];
		const replacement = replacements.get(blockPath.join("."));
		const innerBlocks = Array.isArray(block.innerBlocks)
			? replaceBlocks(block.innerBlocks, blockPath, replacements)
			: [];

		if (!replacement) {
			return {
				...block,
				innerBlocks,
			};
		}

		return {
			...block,
			attributes: replacement,
			innerBlocks,
		};
	});
}
