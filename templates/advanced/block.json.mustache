{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "{{namespace}}/{{slug}}",
	"version": "0.1.0",
	"title": "{{title}}",
	"category": "{{category}}",
	"icon": "{{dashicon}}",
	"description": "{{description}}",
	"keywords": [
		"typia",
		"{{slug}}",
		"custom"
	],
	"example": {
		"attributes": {
			"id": "Example id",
			"version": 1,
			"className": "Example className",
			"content": "",
			"alignment": "left",
			"isVisible": true
		}
	},
	"supports": {
		"html": false,
		"interactivity": {
			"clientNavigation": true
		}
	},
	"textdomain": "{{textdomain}}",
	"editorScript": "file:./index.js",
	"editorStyle": "file:./index.css",
	"style": "file:./style-index.css",
	"viewScript": "file:./view.js",
	"attributes": {
		"content": {
			"type": "string",
			"default": ""
		}
	}
}
