{
  "name": "wp-typia",
  "version": "0.11.1",
  "description": "Canonical CLI package for wp-typia scaffolding and project workflows",
  "packageManager": "bun@1.3.10",
  "type": "module",
  "bin": {
    "wp-typia": "bin/wp-typia.js"
  },
  "files": [
    "bin/",
    "lib/",
    "README.md",
    "package.json"
  ],
  "scripts": {
    "dev": "node bin/wp-typia.js",
    "test": "cd ../create && bun run build && cd ../wp-typia && bun test tests/*.test.ts",
    "test:coverage": "cd ../create && bun run build && cd ../wp-typia && bun test tests/*.test.ts --coverage --coverage-reporter=lcov --coverage-dir=coverage"
  },
  "keywords": [
    "wordpress",
    "gutenberg",
    "typia",
    "cli",
    "scaffold",
    "templates"
  ],
  "author": "imjlk",
  "license": "GPL-2.0-or-later",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/imjlk/wp-typia.git",
    "directory": "packages/wp-typia"
  },
  "bugs": {
    "url": "https://github.com/imjlk/wp-typia/issues"
  },
  "homepage": "https://github.com/imjlk/wp-typia/tree/main/packages/wp-typia#readme",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0",
    "bun": ">=1.3.10"
  },
  "dependencies": {
    "@wp-typia/create": "0.11.1"
  }
}
