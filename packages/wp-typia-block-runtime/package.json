{
  "name": "@wp-typia/block-runtime",
  "version": "0.3.0",
  "description": "Generated-project runtime and metadata sync helpers for wp-typia",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./blocks": {
      "types": "./dist/blocks.d.ts",
      "import": "./dist/blocks.js",
      "default": "./dist/blocks.js"
    },
    "./metadata-core": {
      "types": "./dist/metadata-core.d.ts",
      "import": "./dist/metadata-core.js",
      "default": "./dist/metadata-core.js"
    },
    "./defaults": {
      "types": "./dist/defaults.d.ts",
      "import": "./dist/defaults.js",
      "default": "./dist/defaults.js"
    },
    "./editor": {
      "types": "./dist/editor.d.ts",
      "import": "./dist/editor.js",
      "default": "./dist/editor.js"
    },
    "./identifiers": {
      "types": "./dist/identifiers.d.ts",
      "import": "./dist/identifiers.js",
      "default": "./dist/identifiers.js"
    },
    "./inspector": {
      "types": "./dist/inspector.d.ts",
      "import": "./dist/inspector.js",
      "default": "./dist/inspector.js"
    },
    "./validation": {
      "types": "./dist/validation.d.ts",
      "import": "./dist/validation.js",
      "default": "./dist/validation.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist/",
    "README.md",
    "package.json"
  ],
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.build.json",
    "clean": "rm -rf dist",
    "test:prepare": "bun run build",
    "test": "bun run test:prepare && bun test tests",
    "test:coverage": "bun run test:prepare && bun test tests --coverage --coverage-reporter=text --coverage-reporter=lcov --coverage-dir=coverage",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "author": "imjlk",
  "license": "GPL-2.0-or-later",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/imjlk/wp-typia.git",
    "directory": "packages/wp-typia-block-runtime"
  },
  "bugs": {
    "url": "https://github.com/imjlk/wp-typia/issues"
  },
  "homepage": "https://github.com/imjlk/wp-typia/tree/main/packages/wp-typia-block-runtime#readme",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0",
    "bun": ">=1.3.10"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "dependencies": {
    "typescript": "^5.9.2"
  },
  "devDependencies": {
    "react": "^19.2.0",
    "typia": "^12.0.1"
  }
}
