{
  "name": "@wp-typia/create",
  "version": "0.8.0",
  "description": "Bun-first scaffolding CLI for WordPress Typia block templates",
  "packageManager": "bun@1.3.10",
  "type": "module",
  "main": "dist/runtime/index.js",
  "types": "dist/runtime/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/runtime/index.d.ts",
      "import": "./dist/runtime/index.js",
      "default": "./dist/runtime/index.js"
    },
    "./cli": "./dist/cli.js",
    "./metadata-core": {
      "types": "./dist/runtime/metadata-core.d.ts",
      "import": "./dist/runtime/metadata-core.js",
      "default": "./dist/runtime/metadata-core.js"
    },
    "./runtime/defaults": {
      "types": "./dist/runtime/defaults.d.ts",
      "import": "./dist/runtime/defaults.js",
      "default": "./dist/runtime/defaults.js"
    },
    "./runtime/blocks": {
      "types": "./dist/runtime/blocks.d.ts",
      "import": "./dist/runtime/blocks.js",
      "default": "./dist/runtime/blocks.js"
    },
    "./runtime/editor": {
      "types": "./dist/runtime/editor.d.ts",
      "import": "./dist/runtime/editor.js",
      "default": "./dist/runtime/editor.js"
    },
    "./runtime/inspector": {
      "types": "./dist/runtime/inspector.d.ts",
      "import": "./dist/runtime/inspector.js",
      "default": "./dist/runtime/inspector.js"
    },
    "./runtime/schema-core": {
      "types": "./dist/runtime/schema-core.d.ts",
      "import": "./dist/runtime/schema-core.js",
      "default": "./dist/runtime/schema-core.js"
    },
    "./runtime/validation": {
      "types": "./dist/runtime/validation.d.ts",
      "import": "./dist/runtime/validation.js",
      "default": "./dist/runtime/validation.js"
    },
    "./package.json": "./package.json"
  },
  "bin": {
    "wp-typia": "dist/cli.js"
  },
  "files": [
    "dist/",
    "templates/",
    "README.md",
    "package.json"
  ],
  "scripts": {
    "build": "rm -rf dist && bunli build --runtime node && tsc -p tsconfig.runtime.json",
    "dev": "bun run src/cli.ts",
    "test": "bun run build && bunli test --pattern ./tests/create-cli.test.ts && bunli test --pattern ./tests/import-policy.test.ts && bunli test --pattern ./tests/migrations.test.ts",
    "test:coverage": "bun run build && bunli test --pattern ./tests/create-cli.test.ts --coverage && bunli test --pattern ./tests/import-policy.test.ts --coverage && bunli test --pattern ./tests/migrations.test.ts --coverage && bun test tests/*.test.ts --coverage --coverage-reporter=lcov --coverage-dir=coverage",
    "clean": "rm -rf dist",
    "prepack": "bun run build"
  },
  "keywords": [
    "wordpress",
    "gutenberg",
    "typia",
    "template",
    "scaffold",
    "cli",
    "bun"
  ],
  "author": "imjlk",
  "license": "GPL-2.0-or-later",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/imjlk/wp-typia.git",
    "directory": "packages/create"
  },
  "bugs": {
    "url": "https://github.com/imjlk/wp-typia/issues"
  },
  "homepage": "https://github.com/imjlk/wp-typia/tree/main/packages/create#readme",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0",
    "bun": ">=1.3.10"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "dependencies": {
    "@wp-typia/api-client": "^0.2.0",
    "@wp-typia/rest": "^0.2.0",
    "@wp-typia/block-types": "^0.2.0",
    "mustache": "^4.2.0",
    "npm-package-arg": "^13.0.0",
    "semver": "^7.7.3",
    "tar": "^7.4.3",
    "typescript": "^5.9.2"
  },
  "devDependencies": {
    "bunli": "^0.8.2",
    "react": "^19.2.0",
    "react-devtools-core": "^7.0.1",
    "ws": "^8.18.0"
  }
}
