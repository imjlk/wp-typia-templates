.{{cssClassName}} {
	border: 1px solid #dcdcde;
	border-radius: 12px;
	padding: 16px;
	background: #fff;

	&__meta {
		color: #50575e;
		font-size: 13px;
		margin: 8px 0 0;
	}
}

.wp-block-{{slugKebabCase}}-frontend {
	border: 1px solid #dcdcde;
	border-radius: 12px;
	padding: 16px;
	background: #f6f7f7;

	&__count {
		display: inline-flex;
		min-width: 3rem;
		justify-content: center;
		font-weight: 700;
		margin-inline-end: 12px;
	}

	&__notice {
		color: #7a2a0c;
		font-size: 0.95rem;
		margin: 0 0 12px;
	}
}
