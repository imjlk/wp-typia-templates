<?php
/**
 * Dynamic render entry for the {{title}} block.
 *
 * @package {{pascalCase}}
 */

if ( ! defined( 'ABSPATH' ) ) {
	exit;
}

$validator_path = __DIR__ . '/typia-validator.php';
if ( ! file_exists( $validator_path ) ) {
	return '';
}

$validator = require $validator_path;
if ( ! is_object( $validator ) || ! method_exists( $validator, 'apply_defaults' ) || ! method_exists( $validator, 'validate' ) ) {
	return '';
}

$normalized  = $validator->apply_defaults( is_array( $attributes ) ? $attributes : array() );
$validation  = $validator->validate( $normalized );
$resourceKey = isset( $normalized['resourceKey'] ) ? (string) $normalized['resourceKey'] : '';

if ( empty( $validation['valid'] ) || '' === $resourceKey ) {
	return '';
}

$alignment    = isset( $normalized['alignment'] ) ? (string) $normalized['alignment'] : 'left';
$button_label = isset( $normalized['buttonLabel'] ) ? (string) $normalized['buttonLabel'] : 'Increment';
$content      = isset( $normalized['content'] ) ? (string) $normalized['content'] : '';
$post_id      = get_the_ID();
$storage_mode = '{{dataStorageMode}}';

$wrapper_attributes = get_block_wrapper_attributes(
	array(
		'data-wp-context'      => wp_json_encode(
			array(
				'buttonLabel' => $button_label,
				'count'       => 0,
				'isVisible'   => ! empty( $normalized['isVisible'] ),
				'postId'      => (int) $post_id,
				'restNonce'   => wp_create_nonce( 'wp_rest' ),
				'resourceKey' => $resourceKey,
				'storage'     => $storage_mode,
			)
		),
		'data-wp-interactive'  => '{{slugKebabCase}}',
		'data-wp-init'         => 'callbacks.init',
		'data-wp-run---mounted' => 'callbacks.mounted',
	)
);
?>

<div <?php echo $wrapper_attributes; ?>>
	<div class="wp-block-{{slugKebabCase}}-frontend">
		<p class="wp-block-{{slugKebabCase}}-frontend__content" style="<?php echo esc_attr( 'text-align:' . $alignment ); ?>">
			<?php echo esc_html( $content ); ?>
		</p>
		<?php if ( ! empty( $normalized['showCount'] ) ) : ?>
			<span class="wp-block-{{slugKebabCase}}-frontend__count" data-wp-text="state.count">
				0
			</span>
		<?php endif; ?>
		<button type="button" data-wp-on--click="actions.increment">
			<?php echo esc_html( $button_label ); ?>
		</button>
	</div>
</div>
