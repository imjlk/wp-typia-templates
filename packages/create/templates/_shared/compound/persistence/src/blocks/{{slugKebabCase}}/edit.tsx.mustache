import { __ } from '@wordpress/i18n';
import {
	InspectorControls,
	InnerBlocks,
	RichText,
	useBlockProps,
} from '@wordpress/block-editor';
import {
	Notice,
	PanelBody,
	TextControl,
	ToggleControl,
} from '@wordpress/components';

import type { {{pascalCase}}Attributes } from './types';

const CHILD_BLOCK_NAME = '{{namespace}}/{{slugKebabCase}}-item';
const DEFAULT_TEMPLATE: Parameters< typeof InnerBlocks >[ 0 ][ 'template' ] = [
	[
		CHILD_BLOCK_NAME,
		{
			body: 'Add supporting details for the first internal item.',
			title: 'First Item',
		},
	],
	[
		CHILD_BLOCK_NAME,
		{
			body: 'Add supporting details for the second internal item.',
			title: 'Second Item',
		},
	],
];

export default function Edit( {
	attributes,
	setAttributes,
}: {
	attributes: {{pascalCase}}Attributes;
	setAttributes: ( attrs: Partial< {{pascalCase}}Attributes > ) => void;
} ) {
	const blockProps = useBlockProps( {
		className: '{{cssClassName}}',
	} );

	return (
		<>
			<InspectorControls>
				<PanelBody title={ __( 'Compound Settings', '{{slugSnakeCase}}' ) }>
					<ToggleControl
						label={ __( 'Show dividers between items', '{{slugSnakeCase}}' ) }
						checked={ attributes.showDividers ?? true }
						onChange={ ( value ) => setAttributes( { showDividers: value } ) }
					/>
					<ToggleControl
						label={ __( 'Show persisted count', '{{slugSnakeCase}}' ) }
						checked={ attributes.showCount ?? true }
						onChange={ ( value ) => setAttributes( { showCount: value } ) }
					/>
					<TextControl
						label={ __( 'Button label', '{{slugSnakeCase}}' ) }
						value={ attributes.buttonLabel ?? 'Persist Count' }
						onChange={ ( buttonLabel ) => setAttributes( { buttonLabel } ) }
					/>
					<TextControl
						label={ __( 'Resource key', '{{slugSnakeCase}}' ) }
						value={ attributes.resourceKey ?? '' }
						onChange={ ( resourceKey ) => setAttributes( { resourceKey } ) }
						help={ __( 'Stable key used by the persisted counter endpoint.', '{{slugSnakeCase}}' ) }
					/>
					<Notice status="info" isDismissible={ false }>
						{ __( 'Storage mode: {{dataStorageMode}}', '{{slugSnakeCase}}' ) }
					</Notice>
					<Notice status="info" isDismissible={ false }>
						{ __( 'Persistence policy: {{persistencePolicy}}', '{{slugSnakeCase}}' ) }
					</Notice>
				</PanelBody>
			</InspectorControls>
			<div { ...blockProps }>
				<RichText
					tagName="h3"
					className="{{cssClassName}}__heading"
					value={ attributes.heading }
					onChange={ ( heading ) => setAttributes( { heading } ) }
					placeholder={ __( '{{title}}', '{{slugSnakeCase}}' ) }
				/>
				<RichText
					tagName="p"
					className="{{cssClassName}}__intro"
					value={ attributes.intro ?? '' }
					onChange={ ( intro ) => setAttributes( { intro } ) }
					placeholder={ __(
						'Add and reorder internal items inside this compound block.',
						'{{slugSnakeCase}}'
					) }
				/>
				<p className="{{cssClassName}}__meta">
					{ __( 'Resource key:', '{{slugSnakeCase}}' ) } { attributes.resourceKey || '—' }
				</p>
				<div className="{{cssClassName}}__items">
					<InnerBlocks
						allowedBlocks={ [ CHILD_BLOCK_NAME ] }
						renderAppender={ InnerBlocks.ButtonBlockAppender }
						template={ DEFAULT_TEMPLATE }
						templateLock={ false }
					/>
				</div>
			</div>
		</>
	);
}
