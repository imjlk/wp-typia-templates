.wp-block-{{slugKebabCase}} {
	border: 1px solid #dcdcde;
	border-radius: 12px;
	padding: 1.25rem;
	background: #fff;
}

.wp-block-{{slugKebabCase}}__heading {
	margin: 0 0 0.5rem;
	font-size: 1.2rem;
}

.wp-block-{{slugKebabCase}}__intro {
	margin: 0 0 1rem;
	color: #50575e;
}

.wp-block-{{slugKebabCase}}__items {
	display: grid;
	gap: 0.75rem;
}

.wp-block-{{slugKebabCase}}[data-show-dividers='true'] .wp-block-{{slugKebabCase}}-item {
	border-top: 1px solid #dcdcde;
	padding-top: 0.75rem;
}

.wp-block-{{slugKebabCase}}[data-show-dividers='true'] .wp-block-{{slugKebabCase}}-item:first-child {
	border-top: 0;
	padding-top: 0;
}
