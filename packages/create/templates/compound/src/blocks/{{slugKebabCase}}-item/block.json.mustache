{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "{{namespace}}/{{slugKebabCase}}-item",
	"version": "0.1.0",
	"title": {{compoundChildTitleJson}},
	"category": "widgets",
	"icon": "excerpt-view",
	"description": "Internal item block used by {{title}}.",
	"parent": [
		"{{namespace}}/{{slugKebabCase}}"
	],
	"example": {},
	"supports": {
		"html": false,
		"inserter": false,
		"reusable": false
	},
	"attributes": {
		"title": {
			"type": "string",
			"source": "html",
			"selector": ".wp-block-{{slugKebabCase}}-item__title",
			"default": {{compoundChildTitleJson}}
		},
		"body": {
			"type": "string",
			"source": "html",
			"selector": ".wp-block-{{slugKebabCase}}-item__body",
			"default": "Add supporting details for this internal item."
		}
	},
	"textdomain": "{{textDomain}}",
	"editorScript": "file:./index.js"
}
