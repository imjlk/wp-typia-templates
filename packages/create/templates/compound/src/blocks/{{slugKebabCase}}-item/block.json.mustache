{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "{{namespace}}/{{slugKebabCase}}-item",
	"version": "0.1.0",
	"title": "{{compoundChildTitle}}",
	"category": "widgets",
	"icon": "excerpt-view",
	"description": "Internal item block used by {{title}}.",
	"parent": [
		"{{namespace}}/{{slugKebabCase}}"
	],
	"example": {},
	"supports": {
		"html": false,
		"inserter": false,
		"reusable": false
	},
	"attributes": {
		"title": {
			"type": "string",
			"source": "html",
			"selector": ".wp-block-{{slugKebabCase}}-item__title",
			"default": "{{compoundChildTitle}}"
		},
		"body": {
			"type": "string",
			"source": "html",
			"selector": ".wp-block-{{slugKebabCase}}-item__body",
			"default": "Add supporting details for this internal item."
		}
	},
	"textdomain": "{{slugSnakeCase}}",
	"editorScript": "file:./index.js",
	"editorStyle": "file:./index.css",
	"style": "file:./style-index.css"
}
