{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "{{namespace}}/{{slug}}",
	"title": "{{title}}",
	"description": "{{description}}",
	"category": "widgets",
	"icon": "layout",
	"keywords": ["remote", "{{keyword}}", "{{variantLabel}}"],
	"supports": {
		"html": false,
		"multiple": {{#supportsMultiple}}true{{/supportsMultiple}}{{^supportsMultiple}}false{{/supportsMultiple}}
	},
	"attributes": {
		"content": {
			"type": "string",
			"default": ""
		},
		"variantLabel": {
			"type": "string",
			"default": "{{variantLabel}}"
		},
		"transformedLabel": {
			"type": "string",
			"default": "{{transformedLabel}}"
		}
	},
	"editorScript": "file:./index.js",
	"editorStyle": "file:./index.css",
	"style": "file:./style-index.css"
}
