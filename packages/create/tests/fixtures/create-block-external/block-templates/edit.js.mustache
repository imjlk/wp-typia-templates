import { RichText, useBlockProps } from "@wordpress/block-editor";

export default function Edit({ attributes, setAttributes }) {
	return (
		<div {...useBlockProps({ className: "template-{{variantLabel}}" })}>
			<p>{attributes.transformedLabel || "{{transformedLabel}}"}</p>
			<RichText
				tagName="p"
				value={attributes.content}
				onChange={(content) => setAttributes({ content })}
				placeholder="External {{variantLabel}} template content"
			/>
		</div>
	);
}
