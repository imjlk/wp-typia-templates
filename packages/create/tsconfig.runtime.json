{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "outDir": "./dist/runtime",
    "rootDir": "./src/runtime",
    "declaration": true,
    "declarationMap": false,
    "sourceMap": false,
    "plugins": [],
    "paths": {
      "@wp-typia/block-runtime/metadata-core": [
        "packages/create/build-shims/block-runtime-metadata-core-shim.d.ts"
      ]
    }
  },
  "include": [
    "./src/runtime/**/*",
    "./build-shims/**/*.d.ts"
  ],
  "exclude": [
    "./tests/**/*"
  ]
}
