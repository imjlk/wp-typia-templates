{
  "name": "wp-typia-full",
  "version": "1.2.0",
  "description": "WordPress block template with Typia validation - Full edition with utilities and hooks",
  "main": "index.json",
  "packageManager": "bun@1.3.10",
  "bin": {
    "wp-typia-full": "scripts/setup.js"
  },
  "scripts": {
    "start": "wp-scripts start",
    "build": "wp-scripts build",
    "dev": "bun run start",
    "test": "jest",
    "lint": "wp-scripts lint-js",
    "format": "wp-scripts format",
    "sync-types": "tsx scripts/sync-types-to-block-json.ts",
    "type-check": "tsc --noEmit"
  },
  "keywords": [
    "wordpress",
    "gutenberg",
    "block",
    "typia",
    "typescript",
    "template",
    "hooks",
    "utilities",
    "error-boundary"
  ],
  "author": "Your Name <your.email@example.com>",
  "license": "GPL-2.0-or-later",
  "repository": {
    "type": "git",
    "url": "https://github.com/imjlk/wp-typia-templates.git",
    "directory": "packages/wp-typia-full"
  },
  "bugs": {
    "url": "https://github.com/imjlk/wp-typia-templates/issues"
  },
  "homepage": "https://github.com/imjlk/wp-typia-templates/tree/main/packages/wp-typia-full#readme",
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=8.0.0"
  },
  "files": [
    "src/",
    "template/",
    "scripts/",
    "*.json",
    "*.js",
    "*.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "ajv": "^8.18.0",
    "@types/wordpress__block-editor": "^11.5.17",
    "@types/wordpress__blocks": "^12.5.18",
    "@types/wordpress__components": "^23.8.0",
    "@wordpress/scripts": "^30.22.0",
    "@typia/unplugin": "^12.0.1",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "typia": "^12.0.1"
  },
  "dependencies": {
    "create-wp-typia": "^0.1.0",
    "@wordpress/block-editor": "^15.2.0",
    "@wordpress/blocks": "^15.2.0",
    "@wordpress/components": "^30.2.0",
    "@wordpress/element": "^6.29.0",
    "@wordpress/i18n": "^6.2.0"
  }
}
