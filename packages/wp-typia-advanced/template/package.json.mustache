{
	"name": "{{slugSnakeCase}}",
	"version": "0.1.0",
  "packageManager": "bun@1.3.10",
	"description": "{{description}}",
	"author": "{{author}}",
	"license": "GPL-2.0-or-later",
	"main": "build/index.js",
	"scripts": {
		"sync-types": "tsx scripts/sync-types-to-block-json.ts",
		"build": "bun run sync-types && wp-scripts build",
		"start": "bun run sync-types && wp-scripts start",
		"dev": "bun run start",
		"migration:init": "create-wp-typia migrations init --current-version 1.0.0",
		"migration:snapshot": "create-wp-typia migrations snapshot",
		"migration:diff": "create-wp-typia migrations diff",
		"migration:scaffold": "create-wp-typia migrations scaffold",
		"migration:verify": "create-wp-typia migrations verify --all",
		"lint:js": "wp-scripts lint-js",
		"lint:css": "wp-scripts lint-style",
		"lint": "bun run lint:js && bun run lint:css",
		"format": "wp-scripts format"
	},
	"devDependencies": {
		"ajv": "^8.18.0",
		"@types/wordpress__block-editor": "^11.5.17",
		"@types/wordpress__blocks": "^12.5.18",
