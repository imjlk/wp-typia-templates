{
  "name": "wp-typia-interactivity",
  "version": "1.2.0",
  "description": "WordPress block template with Typia validation - Interactivity API edition",
  "main": "index.json",
  "bin": {
    "wp-typia-interactivity": "scripts/setup.js"
  },
  "scripts": {
    "postinstall": "node scripts/setup.js",
    "start": "wp-scripts start",
    "build": "wp-scripts build",
    "dev": "npm run start",
    "test": "jest",
    "e2e": "playwright test",
    "lint": "wp-scripts lint-js",
    "format": "wp-scripts format",
    "sync-types": "tsx scripts/sync-types-to-block-json.ts",
    "wp-env": "wp-scripts wp-env"
  },
  "keywords": [
    "wordpress",
    "gutenberg",
    "block",
    "typia",
    "typescript",
    "template",
    "interactivity",
    "reactivity",
    "state-management"
  ],
  "author": "Your Name <your.email@example.com>",
  "license": "GPL-2.0-or-later",
  "repository": {
    "type": "git",
    "url": "https://github.com/yourusername/wp-typia-boilerplate.git",
    "directory": "packages/wp-typia-interactivity"
  },
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=8.0.0"
  },
  "files": [
    "src/",
    "template/",
    "scripts/",
    "*.json",
    "*.js",
    "*.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@playwright/test": "^1.40.0",
    "ajv": "^8.18.0",
    "@types/wordpress__block-editor": "^11.5.17",
    "@types/wordpress__blocks": "^12.5.18",
    "@types/wordpress__components": "^23.8.0",
    "@wordpress/scripts": "^30.22.0",
    "@typia/unplugin": "^12.0.1",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "typia": "^12.0.1"
  },
  "dependencies": {
    "@wordpress/block-editor": "^15.2.0",
    "@wordpress/blocks": "^15.2.0",
    "@wordpress/components": "^30.2.0",
    "@wordpress/element": "^6.29.0",
    "@wordpress/i18n": "^6.2.0",
    "@wordpress/interactivity": "^6.29.0"
  }
}
