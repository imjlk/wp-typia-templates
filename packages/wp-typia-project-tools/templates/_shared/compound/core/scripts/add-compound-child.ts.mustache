function renderValidatorsFile(
	childTypeName: string,
	childInterfaceName: string
): string {
	return `import typia from 'typia';
import currentManifest from './manifest-defaults-document';
import type {
\t${ childTypeName },
\t${ childInterfaceName }ValidationResult,
} from './types';
import { createTemplateValidatorToolkit } from '../../validator-toolkit';

const scaffoldValidators = createTemplateValidatorToolkit< ${ childTypeName } >( {
\tassert: typia.createAssert< ${ childTypeName } >(),
\tclone: typia.misc.createClone< ${ childTypeName } >() as (
\t\tvalue: ${ childTypeName },
\t) => ${ childTypeName },
\tis: typia.createIs< ${ childTypeName } >(),
\tmanifest: currentManifest,
\tprune: typia.misc.createPrune< ${ childTypeName } >(),
\trandom: typia.createRandom< ${ childTypeName } >() as (
\t\t...args: unknown[]
\t) => ${ childTypeName },
\tvalidate: typia.createValidate< ${ childTypeName } >(),
} );

export const validate${ childInterfaceName } =
\tscaffoldValidators.validateAttributes as (
\t\tattributes: unknown
\t) => ${ childInterfaceName }ValidationResult;

export const validators = scaffoldValidators.validators;

export const sanitize${ childInterfaceName } =
\tscaffoldValidators.sanitizeAttributes as (
\t\tattributes: Partial< ${ childTypeName } >
\t) => ${ childTypeName };

export const createAttributeUpdater = scaffoldValidators.createAttributeUpdater;
`;
}

function renderEditFile(
	childFolderSlug: string,
	childTypeName: string,
	childInterfaceName: string,
	childTitle: string
): string {
	const childCssClassName = buildBlockCssClassName( PARENT_BLOCK_NAMESPACE, childFolderSlug );

	return `import type { BlockEditProps } from '@wp-typia/block-types/blocks/registration';
import { InnerBlocks, RichText, useBlockProps } from '@wordpress/block-editor';
import { Notice } from '@wordpress/components';
import { __ } from '@wordpress/i18n';

import metadata from './block-metadata';
import {
\tgetChildInnerBlocksConfig,
\thasNestedChildBlocks,
} from '../${ PARENT_BLOCK_SLUG }/children';
import { useTypiaValidation } from './hooks';
import type { ${ childTypeName } } from './types';
import {
\tcreateAttributeUpdater,
\tvalidate${ childInterfaceName },
} from './validators';

type EditProps = BlockEditProps< ${ childTypeName } >;
type CompoundInnerBlocksProps = Parameters< typeof InnerBlocks >[ 0 ] & {
\tdefaultBlock?: [ string, Record< string, unknown > ];
\tdirectInsert?: boolean;
};

const TypedInnerBlocks = InnerBlocks as unknown as (
\tprops: CompoundInnerBlocksProps
) => ReturnType< typeof InnerBlocks >;

export default function Edit( {
\tattributes,
\tsetAttributes,
}: EditProps ) {
\tconst updateAttribute = createAttributeUpdater( attributes, setAttributes );
\tconst { errorMessages, isValid } = useTypiaValidation(
\t\tattributes,
\t\tvalidate${ childInterfaceName }
\t);
\tconst nestedInnerBlocksConfig = getChildInnerBlocksConfig( metadata.name );
\tconst showsNestedChildren = hasNestedChildBlocks( metadata.name );

\treturn (
\t\t<div { ...useBlockProps( { className: '${ childCssClassName }' } ) }>
\t\t\t<RichText
\t\t\t\ttagName="h4"
\t\t\t\tclassName="${ childCssClassName }__title"
\t\t\t\tvalue={ attributes.title ?? '' }
\t\t\t\tonChange={ ( title ) => updateAttribute( 'title', title ) }
\t\t\t\tplaceholder={ __( ${ JSON.stringify( childTitle ) }, '${ TEXT_DOMAIN }' ) }
\t\t\t/>
\t\t\t<RichText
\t\t\t\ttagName="p"
\t\t\t\tclassName="${ childCssClassName }__body"
\t\t\t\tvalue={ attributes.body ?? '' }
\t\t\t\tonChange={ ( body ) => updateAttribute( 'body', body ) }
\t\t\t\tplaceholder={ __( ${ JSON.stringify( CHILD_PLACEHOLDER ) }, '${ TEXT_DOMAIN }' ) }
\t\t\t/>
\t\t\t{ ! isValid && (
\t\t\t\t<Notice status="error" isDismissible={ false }>
\t\t\t\t\t<ul>
\t\t\t\t\t\t{ errorMessages.map( ( error, index ) => (
\t\t\t\t\t\t\t<li key={ index }>{ error }</li>
\t\t\t\t\t\t) ) }
\t\t\t\t\t</ul>
\t\t\t\t</Notice>
\t\t\t) }
\t\t\t{ showsNestedChildren && (
\t\t\t\t<div className="${ childCssClassName }__children">
\t\t\t\t\t<TypedInnerBlocks
\t\t\t\t\t\tdefaultBlock={ nestedInnerBlocksConfig?.defaultBlock }
\t\t\t\t\t\tdirectInsert={ nestedInnerBlocksConfig?.directInsert }
\t\t\t\t\t\torientation={ nestedInnerBlocksConfig?.orientation }
\t\t\t\t\t\trenderAppender={
\t\t\t\t\t\t\tnestedInnerBlocksConfig?.templateLock === 'all'
\t\t\t\t\t\t\t\t? undefined
\t\t\t\t\t\t\t\t: InnerBlocks.ButtonBlockAppender
\t\t\t\t\t\t}
\t\t\t\t\t\ttemplate={ nestedInnerBlocksConfig?.template }
\t\t\t\t\t\ttemplateLock={ nestedInnerBlocksConfig?.templateLock ?? false }
\t\t\t\t\t/>
\t\t\t\t</div>
\t\t\t) }
\t\t</div>
\t);
}
`;
}

