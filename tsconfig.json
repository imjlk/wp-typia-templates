{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@wp-typia/create": [
        "packages/create/src/runtime/index.ts"
      ],
      "@wp-typia/create/metadata-core": [
        "packages/create/src/runtime/metadata-core.ts"
      ],
      "@wp-typia/create/runtime/defaults": [
        "packages/create/src/runtime/defaults.ts"
      ],
      "@wp-typia/create/runtime/editor": [
        "packages/create/src/runtime/editor.ts"
      ],
      "@wp-typia/create/runtime/validation": [
        "packages/create/src/runtime/validation.ts"
      ],
      "@wp-typia/block-types": [
        "packages/wp-typia-block-types/src/index.ts"
      ],
      "@wp-typia/block-types/*": [
        "packages/wp-typia-block-types/src/*"
      ]
    },
    "plugins": [
      { "transform": "typia/lib/transform" }
    ],
    "types": ["bun-types", "node"]
  },
  "include": [
    "packages/*/src/**/*",
    "packages/*/tests/**/*",
    "examples/**/src/**/*",
    "tests/**/*"
  ],
  "exclude": [
    "node_modules",
    "**/build/**",
    "**/dist/**",
    "**/coverage/**",
    "**/*.js"
  ]
}
