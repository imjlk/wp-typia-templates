{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@blocks/*": ["src/blocks/*"],
      "@components/*": ["src/components/*"],
      "@utils/*": ["src/utils/*"],
      "@hooks/*": ["src/hooks/*"],
      "@types/*": ["src/types/*"]
    },
    "plugins": [
      { "transform": "typia/lib/transform" }
    ],
    "types": ["jest", "node"],
    "typeRoots": ["./node_modules/@types", "./tests"]
  },
  "include": [
    "packages/*/src/**/*",
    "test-template/**/src/**/*",
    "tests/**/*",
    "templates/**/*"
  ],
  "exclude": [
    "node_modules",
    "**/build/**",
    "**/dist/**",
    "**/coverage/**",
    "**/*.js"
  ]
}
