{
  "name": "compound-patterns",
  "version": "0.1.0",
  "packageManager": "bun@1.3.11",
  "description": "A parent-and-child WordPress block scaffold with InnerBlocks, optional persistence wiring, and hidden implementation child blocks",
  "author": "imjlk",
  "license": "GPL-2.0-or-later",
  "main": "build/index.js",
  "scripts": {
    "sync": "tsx scripts/sync-project.ts",
    "sync-types": "tsx scripts/sync-types-to-block-json.ts",
    "build": "bun run sync --check && wp-scripts build --experimental-modules",
    "start": "bun run sync && wp-scripts start --experimental-modules",
    "dev": "bun run start",
    "typecheck": "bun run sync --check && tsc --noEmit",
    "lint:js": "node ../../scripts/run-wp-scripts-lint-js-compat.mjs",
    "lint:css": "wp-scripts lint-style",
    "lint": "bun run lint:js && bun run lint:css",
    "format": "wp-scripts format"
  },
  "devDependencies": {
    "@wp-typia/block-runtime": "workspace:*",
    "@wp-typia/block-types": "workspace:*",
    "@typia/unplugin": "^12.0.1",
    "@wordpress/browserslist-config": "^6.42.0",
    "@wordpress/scripts": "^30.22.0",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@types/wordpress__block-editor": "^11.5.17",
    "@types/wordpress__blocks": "^12.5.18",
    "eslint": "8.57.1",
    "prettier": "3.8.2",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "typia": "^12.0.1"
  },
  "dependencies": {
    "@wordpress/block-editor": "^15.2.0",
    "@wordpress/blocks": "^15.2.0",
    "@wordpress/components": "^30.2.0",
    "@wordpress/element": "^6.29.0",
    "@wordpress/i18n": "^6.2.0"
  }
}
