{
	"name": "my-typia-block",
	"private": true,
	"version": "0.1.0",
	"packageManager": "bun@1.3.11",
	"description": "Kitchen-sink showcase app for wp-typia",
	"author": "imjlk",
	"license": "GPL-2.0-or-later",
	"main": "build/index.js",
	"scripts": {
		"sync": "tsx scripts/sync-project.ts",
		"sync-types": "tsx scripts/sync-types-to-block-json.ts",
		"sync-rest": "tsx scripts/sync-rest-contracts.ts",
		"build": "bun run sync --check && wp-scripts build --experimental-modules",
		"start": "bun run sync && wp-scripts start --experimental-modules",
		"dev": "bun run start",
		"migration:init": "npx --yes wp-typia@0.16.8 migrate init --current-migration-version v1",
		"migration:snapshot": "npx --yes wp-typia@0.16.8 migrate snapshot",
		"migration:diff": "npx --yes wp-typia@0.16.8 migrate diff",
		"migration:scaffold": "npx --yes wp-typia@0.16.8 migrate scaffold",
		"migration:doctor": "npx --yes wp-typia@0.16.8 migrate doctor --all",
		"migration:fixtures": "npx --yes wp-typia@0.16.8 migrate fixtures --all",
		"migration:verify": "npx --yes wp-typia@0.16.8 migrate verify --all",
		"migration:fuzz": "npx --yes wp-typia@0.16.8 migrate fuzz --all",
		"typecheck": "bun run sync --check && tsc --noEmit",
		"lint:js": "wp-scripts lint-js",
		"lint:css": "wp-scripts lint-style",
		"lint": "bun run lint:js && bun run lint:css",
		"format": "wp-scripts format"
	},
	"devDependencies": {
		"@wp-typia/block-runtime": "workspace:*",
		"@types/react": "^19.2.2",
		"@types/react-dom": "^19.2.2",
		"@types/wordpress__block-editor": "^11.5.17",
		"@types/wordpress__blocks": "^12.5.18",
		"@typia/unplugin": "^12.0.1",
		"@wordpress/browserslist-config": "^6.42.0",
		"@wordpress/scripts": "^30.22.0",
		"@wp-typia/block-types": "workspace:*",
		"@wp-typia/rest": "workspace:*",
		"ajv": "^8.18.0",
		"prettier": "3.8.2",
		"tsx": "^4.20.5",
		"typescript": "^5.9.2",
		"typia": "^12.0.1"
	},
	"dependencies": {
		"@wordpress/api-fetch": "^7.29.0",
		"@wordpress/block-editor": "^15.2.0",
		"@wordpress/blocks": "^15.2.0",
		"@wordpress/components": "^30.2.0",
		"@wordpress/element": "^6.29.0",
		"@wordpress/i18n": "^6.2.0",
		"@wordpress/interactivity": "^6.29.0"
	}
}
