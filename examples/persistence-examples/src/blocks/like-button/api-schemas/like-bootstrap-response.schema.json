{
	"$schema": "https://json-schema.org/draft/2020-12/schema",
	"additionalProperties": false,
	"properties": {
		"canWrite": {
			"type": "boolean"
		},
		"likedByCurrentUser": {
			"type": "boolean"
		},
		"restNonce": {
			"type": "string",
			"minLength": 1,
			"maxLength": 128
		}
	},
	"required": [
		"canWrite",
		"likedByCurrentUser"
	],
	"title": "PersistenceLikeBootstrapResponse",
	"type": "object",
	"allOf": [
		{
			"if": {
				"properties": {
					"canWrite": {
						"const": true
					}
				},
				"required": [
					"canWrite"
				]
			},
			"then": {
				"required": [
					"restNonce"
				]
			},
			"else": {
				"not": {
					"required": [
						"restNonce"
					]
				}
			}
		}
	]
}