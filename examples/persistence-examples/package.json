{
	"name": "persistence-examples",
	"private": true,
	"version": "0.1.0",
	"packageManager": "bun@1.3.11",
	"description": "Policy-aware persistence example blocks for wp-typia",
	"author": "imjlk",
	"license": "GPL-2.0-or-later",
	"scripts": {
		"sync": "tsx scripts/sync-project.ts",
		"sync-types": "tsx scripts/sync-types-to-block-json.ts",
		"sync-rest": "tsx scripts/sync-rest-contracts.ts",
		"sync-wordpress-ai": "tsx scripts/sync-wordpress-ai-projections.ts",
		"build": "bun run sync --check && bun run sync-wordpress-ai --check && wp-scripts build --experimental-modules",
		"start": "bun run sync && bun run sync-wordpress-ai && wp-scripts start --experimental-modules",
		"dev": "bun run start",
		"typecheck": "bun run sync --check && bun run sync-wordpress-ai --check && tsc --noEmit",
		"lint:js": "wp-scripts lint-js",
		"lint:css": "wp-scripts lint-style",
		"lint": "bun run lint:js && bun run lint:css",
		"format": "wp-scripts format"
	},
	"devDependencies": {
		"@wp-typia/api-client": "workspace:*",
		"@wp-typia/block-runtime": "workspace:*",
		"@types/react": "^19.2.2",
		"@types/react-dom": "^19.2.2",
		"@types/wordpress__block-editor": "^11.5.17",
		"@types/wordpress__blocks": "^12.5.18",
		"@typia/unplugin": "^12.0.1",
		"@wordpress/browserslist-config": "^6.42.0",
		"@wordpress/scripts": "^30.22.0",
		"@wp-typia/block-types": "workspace:*",
		"@wp-typia/rest": "workspace:*",
		"ajv": "^8.18.0",
		"prettier": "3.8.2",
		"tsx": "^4.20.5",
		"typescript": "^5.9.2",
		"typia": "^12.0.1"
	},
	"dependencies": {
		"@wordpress/api-fetch": "^7.29.0",
		"@wordpress/block-editor": "^15.2.0",
		"@wordpress/blocks": "^15.2.0",
		"@wordpress/components": "^30.2.0",
		"@wordpress/element": "^6.29.0",
		"@wordpress/i18n": "^6.2.0",
		"@wordpress/interactivity": "^6.29.0"
	}
}
