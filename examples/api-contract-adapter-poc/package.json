{
	"name": "api-contract-adapter-poc",
	"private": true,
	"version": "0.1.0",
	"packageManager": "bun@1.3.11",
	"description": "Non-PHP adapter proof of concept for wp-typia REST endpoint manifests",
	"author": "imjlk",
	"license": "GPL-2.0-or-later",
	"scripts": {
		"sync-typia-llm": "tsx scripts/sync-typia-llm.ts",
		"build": "bun run typecheck",
		"start": "tsx src/server.ts",
		"typecheck": "bun run sync-typia-llm --check && tsc --noEmit"
	},
	"devDependencies": {
		"@wp-typia/api-client": "workspace:*",
		"@wp-typia/block-runtime": "workspace:*",
		"ajv": "^8.18.0",
		"@types/node": "^24.0.0",
		"@wp-typia/project-tools": "workspace:*",
		"ts-patch": "^3.3.0",
		"tsx": "^4.20.5",
		"typescript": "^5.9.2",
		"typia": "^12.0.1"
	}
}
