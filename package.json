{
  "name": "wp-typia",
  "version": "1.0.0",
  "description": "Bun-first WordPress block templates with Typia-powered metadata generation",
  "private": true,
  "packageManager": "bun@1.3.10",
  "workspaces": [
    "packages/create",
    "packages/create-wp-typia",
    "packages/wp-typia-rest",
    "packages/wp-typia-block-types",
    "examples/*"
  ],
  "scripts": {
    "packages:build": "bun run --filter @wp-typia/block-types build && bun run --filter @wp-typia/rest build && bun run --filter @wp-typia/create build",
    "examples:build": "bun run --filter my-typia-block build",
    "examples:dev": "bun run --filter my-typia-block --if-present dev",
    "examples:lint": "bun run --filter my-typia-block --if-present lint",
    "examples:format": "bun run --filter my-typia-block --if-present format",
    "examples:typecheck": "bun run --filter my-typia-block --if-present typecheck",
    "examples:test:e2e": "bun run examples:build && bun run examples:wp-env:wait:test && playwright test",
    "examples:test:e2e:ci": "bun run examples:wp-env:wait:test && playwright test",
    "examples:test:e2e:matrix": "bun run examples:build && bun run examples:wp-env:wait:test && PLAYWRIGHT_MATRIX=1 playwright test",
    "examples:test:e2e:matrix:ci": "bun run examples:wp-env:wait:test && PLAYWRIGHT_MATRIX=1 playwright test",
    "examples:wp-env:start": "wp-env start",
    "examples:wp-env:stop": "wp-env stop",
    "examples:wp-env:reset": "wp-env destroy all && wp-env start",
    "examples:wp-env:start:test": "wp-env start --config=.wp-env.test.json",
    "examples:wp-env:stop:test": "wp-env stop --config=.wp-env.test.json",
    "examples:wp-env:reset:test": "wp-env destroy all --config=.wp-env.test.json && wp-env start --config=.wp-env.test.json",
    "examples:wp-env:wait:test": "node scripts/wait-for-wp-env.mjs http://localhost:8889 180000 .wp-env.test.json",
    "build": "bun run packages:build && bun run examples:build",
    "test": "bun run test:unit && bun run test:cli",
    "test:unit": "bun test tests/unit",
    "test:cli": "bun run --filter @wp-typia/rest test && bun run --filter @wp-typia/create test",
    "test:generated-smoke": "node scripts/run-generated-project-smoke.mjs",
    "test:coverage": "bun run test:unit:coverage && bun run test:cli:coverage",
    "test:unit:coverage": "bun test tests/unit --coverage --coverage-reporter=text --coverage-reporter=lcov --coverage-dir=coverage/unit",
    "test:cli:coverage": "bun run --filter @wp-typia/rest test && bun run --filter @wp-typia/create test:coverage",
    "test:watch": "bun test tests/unit --watch",
    "test:e2e": "bun run examples:test:e2e",
    "test:e2e:matrix": "bun run examples:test:e2e:matrix",
    "lint": "bun run examples:lint",
    "format": "bun run examples:format",
    "clean": "bun run --workspaces --if-present clean && rm -rf node_modules",
    "dev": "bun run examples:dev",
    "typecheck": "tsc --noEmit",
    "release": "sampo release",
    "publish": "sampo publish",
    "publish:oidc": "bash scripts/publish-oidc.sh",
    "sampo:add": "sampo add",
    "docs:dev": "typedoc --watch",
    "docs:build": "typedoc",
    "wp-env:start": "bun run examples:wp-env:start",
    "wp-env:stop": "bun run examples:wp-env:stop",
    "wp-env:reset": "bun run examples:wp-env:reset"
  },
  "keywords": [
    "wordpress",
    "gutenberg",
    "block",
    "typia",
    "typescript",
    "template",
    "monorepo"
  ],
  "author": "imjlk",
  "license": "GPL-2.0-or-later",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/imjlk/wp-typia.git"
  },
  "bugs": {
    "url": "https://github.com/imjlk/wp-typia/issues"
  },
  "homepage": "https://github.com/imjlk/wp-typia#readme",
  "devDependencies": {
    "@playwright/test": "^1.40.0",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@types/node": "^20.9.0",
    "@types/wordpress__block-editor": "^11.5.17",
    "@types/wordpress__blocks": "^12.5.18",
    "@types/wordpress__components": "^23.8.0",
    "@wordpress/browserslist-config": "^6.42.0",
    "@wordpress/env": "^11.2.0",
    "@types/wordpress__element": "^2.14.1",
    "@types/wordpress__i18n": "^3.11.0",
    "bun-types": "^1.3.11",
    "typedoc": "^0.25.4",
    "typedoc-plugin-markdown": "^3.16.0",
    "typescript": "^5.9.2"
  },
  "dependencies": {
    "typia": "^12.0.1"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0",
    "bun": ">=1.3.10"
  }
}
