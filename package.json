{
  "name": "wp-typia-templates",
  "version": "1.0.0",
  "description": "Bun-first WordPress block templates with Typia-powered metadata generation",
  "private": true,
  "packageManager": "bun@1.3.10",
  "workspaces": [
    "packages/*",
    "test-template/*"
  ],
  "scripts": {
    "build": "bun run --filter create-wp-typia build && bun run --filter my-typia-block build",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "test:watch": "jest --watch",
    "test:e2e": "playwright test",
    "lint": "bun run --filter my-typia-block --if-present lint",
    "format": "bun run --filter my-typia-block --if-present format",
    "clean": "bun run --workspaces --if-present clean && rm -rf node_modules",
    "dev": "bun run --filter my-typia-block --if-present dev",
    "typecheck": "tsc --noEmit",
    "release": "changeset publish",
    "version": "changeset version",
    "docs:dev": "typedoc --watch",
    "docs:build": "typedoc",
    "wp-env:start": "wp-env start",
    "wp-env:stop": "wp-env stop",
    "wp-env:reset": "wp-env destroy all && wp-env start"
  },
  "keywords": [
    "wordpress",
    "gutenberg",
    "block",
    "typia",
    "typescript",
    "template",
    "monorepo"
  ],
  "author": "imjlk",
  "license": "GPL-2.0-or-later",
  "repository": {
    "type": "git",
    "url": "https://github.com/imjlk/wp-typia-templates.git"
  },
  "bugs": {
    "url": "https://github.com/imjlk/wp-typia-templates/issues"
  },
  "homepage": "https://github.com/imjlk/wp-typia-templates#readme",
  "devDependencies": {
    "@changesets/cli": "^2.27.0",
    "@playwright/test": "^1.40.0",
    "@types/jest": "^29.5.8",
    "@types/node": "^20.9.0",
    "@types/wordpress__block-editor": "^11.5.17",
    "@types/wordpress__blocks": "^12.5.18",
    "@types/wordpress__components": "^23.8.0",
    "@wordpress/browserslist-config": "^6.42.0",
    "@types/wordpress__element": "^2.14.1",
    "@types/wordpress__i18n": "^3.11.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "ts-jest": "^29.1.1",
    "typedoc": "^0.25.4",
    "typedoc-plugin-markdown": "^3.16.0",
    "typescript": "^5.9.2"
  },
  "dependencies": {
    "typia": "^12.0.1"
  },
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=8.0.0",
    "bun": ">=1.3.10"
  }
}
